import 'dart:async';
import 'dart:io';
import 'dart:math';
import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:audioplayers/audioplayers.dart';
import 'package:file_picker/file_picker.dart';

void main() {
  runApp(const PomodoroApp());
}

class PomodoroApp extends StatelessWidget {
  const PomodoroApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Pomodoro',
      debugShowCheckedModeBanner: false,
      theme: ThemeData(
        useMaterial3: true,
        colorScheme: ColorScheme.fromSeed(
          seedColor: const Color(0xFFE74C3C),
          brightness: Brightness.dark,
          surface: const Color(0xFF16213E),
        ),
        scaffoldBackgroundColor: const Color(0xFF16213E),
        navigationBarTheme: NavigationBarThemeData(
          indicatorColor: const Color(0xFFE74C3C).withValues(alpha: 0.3),
          labelTextStyle: WidgetStateProperty.all(
            const TextStyle(color: Colors.white70, fontSize: 12),
          ),
          iconTheme: WidgetStateProperty.all(
            const IconThemeData(color: Colors.white70),
          ),
        ),
      ),
      home: const PomodoroHome(),
    );
  }
}

enum Phase { idle, work, breakTime }

class PomodoroHome extends StatefulWidget {
  const PomodoroHome({super.key});

  @override
  State<PomodoroHome> createState() => _PomodoroHomeState();
}

class _PomodoroHomeState extends State<PomodoroHome> {
  int _currentTab = 0;

  int workMinutes = 25;
  int breakMinutes = 5;
  int totalCycles = 4;

  Phase currentPhase = Phase.idle;
  bool isRunning = false;
  int currentCycle = 0;
  int remainingSeconds = 25 * 60;
  Timer? _timer;

  String? _soundPath;
  final _player = AudioPlayer();

  @override
  void dispose() {
    _timer?.cancel();
    _player.dispose();
    super.dispose();
  }

  Future<void> _pickSound() async {
    final result = await FilePicker.platform.pickFiles(
      type: FileType.custom,
      allowedExtensions: ['mp3', 'wav', 'ogg', 'aac', 'm4a', 'flac'],
    );
    if (result != null && result.files.single.path != null) {
      setState(() => _soundPath = result.files.single.path);
    }
  }

  Future<void> _playSound() async {
    if (_soundPath == null) return;
    if (!File(_soundPath!).existsSync()) return;
    await _player.stop();
    await _player.play(DeviceFileSource(_soundPath!));
  }

  void _startSession() {
    if (!isRunning && currentPhase == Phase.idle) {
      setState(() {
        currentPhase = Phase.work;
        currentCycle = 1;
        remainingSeconds = workMinutes * 60;
        _currentTab = 0;
      });
    }
    _timer?.cancel();
    setState(() => isRunning = true);
    _timer = Timer.periodic(const Duration(seconds: 1), (_) {
      if (remainingSeconds > 0) {
        setState(() => remainingSeconds--);
      } else {
        _onPhaseComplete();
      }
    });
  }

  void _onPhaseComplete() {
    _timer?.cancel();
    _playSound();
    if (currentPhase == Phase.work) {
      if (currentCycle >= totalCycles) {
        setState(() {
          isRunning = false;
          currentPhase = Phase.idle;
          currentCycle = 0;
          remainingSeconds = workMinutes * 60;
        });
        _showDoneDialog();
      } else {
        setState(() {
          currentPhase = Phase.breakTime;
          remainingSeconds = breakMinutes * 60;
          _currentTab = 1;
        });
        _startSession();
      }
    } else {
      setState(() {
        currentPhase = Phase.work;
        currentCycle++;
        remainingSeconds = workMinutes * 60;
        _currentTab = 0;
      });
      _startSession();
    }
  }

  void _pause() {
    _timer?.cancel();
    setState(() => isRunning = false);
  }

  void _reset() {
    _timer?.cancel();
    setState(() {
      isRunning = false;
      currentPhase = Phase.idle;
      currentCycle = 0;
      remainingSeconds = workMinutes * 60;
    });
  }

  void _showDoneDialog() {
    showDialog(
      context: context,
      builder: (_) => AlertDialog(
        backgroundColor: const Color(0xFF0F3460),
        title: const Text('انتهيت! 🎉', style: TextStyle(color: Colors.white)),
        content: Text(
          'أتمت $totalCycles دورة بومودورو بنجاح!',
          style: const TextStyle(color: Colors.white70),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('تمام', style: TextStyle(color: Color(0xFFE74C3C))),
          ),
        ],
      ),
    );
  }

  String get _timeDisplay {
    final m = remainingSeconds ~/ 60;
    final s = remainingSeconds % 60;
    return '${m.toString().padLeft(2, '0')}:${s.toString().padLeft(2, '0')}';
  }

  double get _progress {
    final total = currentPhase == Phase.work
        ? workMinutes * 60
        : currentPhase == Phase.breakTime
            ? breakMinutes * 60
            : workMinutes * 60;
    if (total == 0) return 0;
    return 1 - (remainingSeconds / total);
  }

  Color get _phaseColor {
    return currentPhase == Phase.breakTime
        ? const Color(0xFF2ECC71)
        : const Color(0xFFE74C3C);
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: SafeArea(
        child: IndexedStack(
          index: _currentTab,
          children: [
            _WorkTab(
              workMinutes: workMinutes,
              onMinutesChanged: (v) {
                setState(() {
                  workMinutes = v;
                  if (currentPhase == Phase.idle) remainingSeconds = v * 60;
                });
              },
              timeDisplay: _timeDisplay,
              progress: _progress,
              phaseColor: _phaseColor,
              currentPhase: currentPhase,
              isRunning: isRunning,
              currentCycle: currentCycle,
              totalCycles: totalCycles,
              onStart: _startSession,
              onPause: _pause,
              onReset: _reset,
            ),
            _BreakTab(
              breakMinutes: breakMinutes,
              onMinutesChanged: (v) => setState(() => breakMinutes = v),
              timeDisplay: _timeDisplay,
              progress: _progress,
              phaseColor: _phaseColor,
              currentPhase: currentPhase,
              isRunning: isRunning,
              currentCycle: currentCycle,
              totalCycles: totalCycles,
              onStart: _startSession,
              onPause: _pause,
              onReset: _reset,
            ),
            _CyclesTab(
              totalCycles: totalCycles,
              currentCycle: currentCycle,
              currentPhase: currentPhase,
              onCyclesChanged: (v) => setState(() => totalCycles = v),
              soundPath: _soundPath,
              onPickSound: _pickSound,
              onPreviewSound: _playSound,
              onClearSound: () => setState(() => _soundPath = null),
            ),
          ],
        ),
      ),
      bottomNavigationBar: NavigationBar(
        selectedIndex: _currentTab,
        onDestinationSelected: (i) => setState(() => _currentTab = i),
        destinations: const [
          NavigationDestination(
            icon: Icon(Icons.timer_outlined),
            selectedIcon: Icon(Icons.timer, color: Color(0xFFE74C3C)),
            label: 'Work',
          ),
          NavigationDestination(
            icon: Icon(Icons.coffee_outlined),
            selectedIcon: Icon(Icons.coffee, color: Color(0xFF2ECC71)),
            label: 'Break',
          ),
          NavigationDestination(
            icon: Icon(Icons.repeat_outlined),
            selectedIcon: Icon(Icons.repeat, color: Color(0xFF3498DB)),
            label: 'Cycles',
          ),
        ],
      ),
    );
  }
}

// ─── Work Tab ────────────────────────────────────────────────────────────────

class _WorkTab extends StatelessWidget {
  final int workMinutes;
  final ValueChanged<int> onMinutesChanged;
  final String timeDisplay;
  final double progress;
  final Color phaseColor;
  final Phase currentPhase;
  final bool isRunning;
  final int currentCycle;
  final int totalCycles;
  final VoidCallback onStart;
  final VoidCallback onPause;
  final VoidCallback onReset;

  const _WorkTab({
    required this.workMinutes,
    required this.onMinutesChanged,
    required this.timeDisplay,
    required this.progress,
    required this.phaseColor,
    required this.currentPhase,
    required this.isRunning,
    required this.currentCycle,
    required this.totalCycles,
    required this.onStart,
    required this.onPause,
    required this.onReset,
  });

  bool get _isActive => currentPhase == Phase.work;

  @override
  Widget build(BuildContext context) {
    return Padding(
      padding: const EdgeInsets.symmetric(horizontal: 24),
      child: Column(
        children: [
          const SizedBox(height: 32),
          const Text(
            'Work Timer',
            style: TextStyle(
              color: Colors.white,
              fontSize: 26,
              fontWeight: FontWeight.bold,
              letterSpacing: 1.5,
            ),
          ),
          if (currentCycle > 0) ...[
            const SizedBox(height: 8),
            Text(
              'Cycle $currentCycle / $totalCycles',
              style: TextStyle(color: phaseColor, fontSize: 14),
            ),
          ],
          const SizedBox(height: 40),
          _CircularTimer(
            timeDisplay: _isActive ? timeDisplay : _formatMinutes(workMinutes),
            progress: _isActive ? progress : 0,
            color: const Color(0xFFE74C3C),
            isActive: _isActive,
          ),
          const SizedBox(height: 40),
          if (!isRunning || !_isActive)
            _MinutePicker(
              label: 'مدة الشغل',
              minutes: workMinutes,
              onChanged: onMinutesChanged,
              color: const Color(0xFFE74C3C),
              enabled: currentPhase == Phase.idle,
            ),
          const Spacer(),
          _ControlButtons(
            isRunning: isRunning && _isActive,
            currentPhase: currentPhase,
            onStart: onStart,
            onPause: onPause,
            onReset: onReset,
            color: const Color(0xFFE74C3C),
          ),
          const SizedBox(height: 24),
        ],
      ),
    );
  }

  String _formatMinutes(int m) => '${m.toString().padLeft(2, '0')}:00';
}

